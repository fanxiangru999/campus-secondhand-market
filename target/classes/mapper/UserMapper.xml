<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.market.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.campus.market.entity.User">
        <id column="id" property="id"/>
        <result column="student_id" property="studentId"/>
        <result column="username" property="username"/>
        <result column="user_type" property="userType"/>
        <result column="password" property="password"/>
        <result column="phone" property="phone"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByStudentId" resultMap="BaseResultMap">
        SELECT * FROM users WHERE student_id = #{studentId}
    </select>

    <insert id="insert" parameterType="com.campus.market.entity.User">
        INSERT INTO users (student_id, username, user_type, password, phone)
        VALUES (#{studentId}, #{username}, #{userType}, #{password}, #{phone})
    </insert>

    <update id="update" parameterType="com.campus.market.entity.User">
        UPDATE users
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="phone != null">phone = #{phone},</if>
        </set>
        WHERE student_id = #{studentId}
    </update>

    <delete id="deleteByStudentId">
        DELETE FROM users WHERE student_id = #{studentId}
    </delete>

    <select id="selectAllStudents" resultMap="BaseResultMap">
        SELECT * FROM users WHERE user_type = 'student' ORDER BY created_at DESC
    </select>

    <update id="resetPassword">
        UPDATE users SET password = #{password} WHERE student_id = #{studentId}
    </update>

    <select id="countAll" resultType="java.lang.Long">
        SELECT COUNT(*) FROM users
    </select>

</mapper>
